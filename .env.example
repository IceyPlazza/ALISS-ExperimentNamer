# Copy this file to .env and fill in your tokens from https://api.slack.com/apps

# Bot User OAuth Token (starts with xoxb-), from OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-...

# App-Level Token with connections:write scope (starts with xapp-), from Basic Information > App-Level Tokens
SLACK_APP_TOKEN=xapp-...

# ----------------------------------------------------------------------------
# Box (https://app.box.com/developers/console)
# ----------------------------------------------------------------------------

# dev_token = quick start: 60-minute Developer Token from your Box app's
#             Configuration page, acts as YOU (has your folder access).
# ccg       = production: Client Credentials Grant service account. Needs
#             admin authorization in the Box Admin Console, and the service
#             account must be invited as a collaborator on the ARPA-H folder.
BOX_AUTH_METHOD=dev_token

# dev_token auth
BOX_DEVELOPER_TOKEN=

# ccg auth (only if BOX_AUTH_METHOD=ccg)
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_ENTERPRISE_ID=

# Folder IDs: open each folder at app.box.com — the number in the URL after
# /folder/ is the id. NOTE: do not put comments on the same line as a value;
# python-dotenv treats them as part of the value.
# For a safe dry run, point all three at a test folder tree instead of
# ARPA-H — names/paths shown in Slack are read live from Box.

# Root folder containing both (production: ARPA-H; future home of experiment_index.csv)
BOX_ROOT_FOLDER_ID=
# "Data Collection and Scans" directory (production: under ARPA-H)
BOX_SCANS_FOLDER_ID=
# "Experiments" directory (production: under ARPA-H)
BOX_EXPERIMENTS_FOLDER_ID=

