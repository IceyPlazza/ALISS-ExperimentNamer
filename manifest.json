{
    "display_information": {
        "name": "Experiment Namer",
        "description": "Generates unique names for new lab experiments",
        "background_color": "#4a154b"
    },
    "features": {
        "bot_user": {
            "display_name": "Experiment Namer",
            "always_online": true
        },
        "slash_commands": [
            {
                "command": "/experiment",
                "description": "Name and track lab experiments",
                "usage_hint": "new | track <name> | date <date> | legacy [link] | delete <name|empty> | category <bph|cao>",
                "should_escape": false
            }
        ]
    },
    "oauth_config": {
        "scopes": {
            "bot": [
                "commands",
                "chat:write"
            ]
        }
    },
    "settings": {
        "interactivity": {
            "is_enabled": true
        },
        "org_deploy_enabled": false,
        "socket_mode_enabled": true,
        "token_rotation_enabled": false
    }
}
